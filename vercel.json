{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/catalogo", "destination": "/catalogo.html" },
    { "source": "/producto", "destination": "/producto.html" }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/", "statusCode": 301 },
    { "source": "/catalogo.html", "destination": "/catalogo", "statusCode": 301 },
    { "source": "/producto.html", "destination": "/producto", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
