# ============================================================
# ESENCIA — Variables de entorno (plantilla)
# Copia este archivo a .env y rellena con tus llaves reales.
# NUNCA subas el archivo .env al repositorio (está en .gitignore).
# ============================================================

# Culqi (pasarela de pagos) — usa llaves de SANDBOX por ahora
CULQI_PUBLIC_KEY=pk_test_aqui_tu_llave_publica
CULQI_SECRET_KEY=sk_test_aqui_tu_llave_secreta

# Notion (CRM de pedidos)
NOTION_API_KEY=secret_aqui_tu_notion_token

# Resend (emails transaccionales)
RESEND_API_KEY=re_aqui_tu_resend_key

# Dominio del sitio (usado para CORS y enlaces en emails)
DOMAIN=http://localhost:3000
